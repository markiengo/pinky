// Prisma schema – AI Exam Prep App
// Local dev: SQLite | Railway: PostgreSQL (auto-swapped in build step)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users ──────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  plan         String   @default("basic") // "basic" | "premium"
  createdAt    DateTime @default(now()) @map("created_at")

  quizAttempts QuizAttempt[]
  studyPlan    StudyPlan?

  @@map("users")
}

// ─── Study Plan ───────────────────────────────────────────────────
model StudyPlan {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects StudySubject[]
  sessions StudySession[]

  @@map("study_plans")
}

// ─── Study Subject ──────────────────────────────────────────────────
model StudySubject {
  id          String   @id @default(cuid())
  planId      String   @map("plan_id")
  name        String
  examDate    DateTime @map("exam_date")
  dailyHours  Float    @map("daily_hours")
  totalHours  Float    @map("total_hours")
  color       String   @default("#9F7AEA")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  plan     StudyPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  sessions StudySession[]

  @@map("study_subjects")
}

// ─── Study Session ──────────────────────────────────────────────────
model StudySession {
  id         String    @id @default(cuid())
  planId     String    @map("plan_id")
  subjectId  String    @map("subject_id")
  title      String
  startTime  DateTime  @map("start_time")
  endTime    DateTime  @map("end_time")
  status     String    @default("planned") // "planned" | "done" | "skipped"
  deThiId    String?   @map("de_thi_id")
  description String?  @map("description")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  plan    StudyPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  subject StudySubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("study_sessions")
}

// ─── Subjects ───────────────────────────────────────────────────────
model Subject {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  deThi        DeThi[]
  questions    Question[]
  quizAttempts QuizAttempt[]

  @@map("subjects")
}

// ─── Đề thi (Exam papers) ──────────────────────────────────────────
model DeThi {
  id              String   @id @default(cuid())
  subjectId       String   @map("subject_id")
  title           String
  source          String   @default("")
  tags            String   @default("[]") // JSON array stored as text
  normalizedTitle String   @default("") @map("normalized_title")
  createdAt       DateTime @default(now()) @map("created_at")

  subject       Subject         @relation(fields: [subjectId], references: [id])
  deThiQuestions DeThiQuestion[]
  quizAttempts  QuizAttempt[]

  @@map("de_thi")
}

// ─── Questions ──────────────────────────────────────────────────────
model Question {
  id            String   @id @default(cuid())
  subjectId     String   @map("subject_id")
  type          String   @default("mcq") // "mcq" | "essay"
  content       String
  options       String?  // JSON array for MCQ options
  correctAnswer String   @default("") @map("correct_answer")
  explanation  String   @default("") // Markdown: step-by-step working + formulas
  tags          String   @default("[]") // JSON array stored as text

  subject       Subject         @relation(fields: [subjectId], references: [id])
  deThiQuestions DeThiQuestion[]
  quizAnswers   QuizAnswer[]

  @@map("questions")
}

// ─── Junction: Đề thi ↔ Questions ──────────────────────────────────
model DeThiQuestion {
  id          String   @id @default(cuid())
  deThiId     String   @map("de_thi_id")
  questionId  String   @map("question_id")
  orderIndex  Int      @map("order_index")

  deThi     DeThi     @relation(fields: [deThiId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([deThiId, orderIndex])
  @@unique([deThiId, questionId])
  @@map("de_thi_questions")
}

// ─── Quiz attempts ──────────────────────────────────────────────────
model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  deThiId        String   @map("de_thi_id")
  subjectId      String   @map("subject_id")
  mode           String   @default("practice") // "practice" | "test"
  score          Int      @default(0)
  totalQuestions Int      @default(0) @map("total_questions")
  percentage     Float    @default(0)
  completedAt    DateTime @default(now()) @map("completed_at")

  user    User         @relation(fields: [userId], references: [id])
  deThi   DeThi        @relation(fields: [deThiId], references: [id])
  subject Subject      @relation(fields: [subjectId], references: [id])
  answers QuizAnswer[]

  @@map("quiz_attempts")
}

// ─── Quiz answers ───────────────────────────────────────────────────
model QuizAnswer {
  id         String   @id @default(cuid())
  attemptId  String   @map("attempt_id")
  questionId String   @map("question_id")
  userAnswer String   @default("") @map("user_answer")
  isCorrect  Boolean? @map("is_correct")
  createdAt  DateTime @default(now()) @map("created_at")

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id])
  question Question    @relation(fields: [questionId], references: [id])

  @@map("quiz_answers")
}
